{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "P2P File Deployer",
  "version": "0.1.0",
  "identifier": "com.NMFCC.app",
  "build": {
    "beforeDevCommand": "pnpm start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist/net-monitor-for-computer-center/browser"
  },
  "app": {
    "windows": [
      {
        "title": "P2P File Deployer",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "additionalBrowserArgs": "--user-data-dir=%LOCALAPPDATA%\\com.NMFCC.app\\webview2"
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
